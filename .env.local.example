# Supabase project settings (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only: never expose to the browser
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Reservation and review emails (Resend)
RESEND_API_KEY=re_your-resend-api-key
RESERVAS_EMAIL_FROM="Karuma Sushi & Grill <reservas@your-domain.com>"
RESERVAS_EMAIL_REPLY_TO=reservas@your-domain.com

# Signs the administrator login cookie. Use at least 32 random characters.
KARUMA_AUTH_SECRET=generate-a-random-secret-at-least-32-characters
# Optional overrides for the built-in administrator.
KARUMA_ADMIN_USERNAME=karuma
KARUMA_ADMIN_PASSWORD_HASH=your-bcrypt-password-hash

# Optional server-only JSON map. If omitted, the built-in 4-digit staff PINs are used.
KARUMA_ATTENDANCE_PINS={"employee-id":"0000"}

# Mobile attendance geofence. Copy the restaurant pin from Google Maps.
KARUMA_STORE_LATITUDE=39.4690812
KARUMA_STORE_LONGITUDE=-0.3751925
KARUMA_ATTENDANCE_RADIUS_METERS=150
KARUMA_ATTENDANCE_MAX_ACCURACY_METERS=100

# Automatically generated when a Vercel Blob store is connected
BLOB_READ_WRITE_TOKEN=vercel_blob_rw_your-store-token

# Daily POS synchronization
KARUMA_SYNC_SECRET=generate-a-random-secret-at-least-16-characters
CRON_SECRET=generate-a-different-random-secret-at-least-16-characters
RESTOSUITE_API_URL=https://pos-provider.example/api/daily-sales
RESTOSUITE_API_TOKEN=your-pos-api-token
RESTOSUITE_LOCATION_ID=karuma-valencia
# Optional provider-specific settings
RESTOSUITE_API_KEY_HEADER=Authorization
RESTOSUITE_API_KEY_PREFIX="Bearer "
RESTOSUITE_DATE_PARAM=date
RESTOSUITE_LOCATION_PARAM=locationId
