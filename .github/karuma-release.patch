+  type: ShiftType,
+): "success" | "info" | "warning" | "neutral" | "danger" {
+  switch (type) {
+    case "lunch":
+      return "info";
+    case "evening":
+      return "warning";
+    case "full":
+      return "success";
+    case "rest":
+      return "neutral";
+    case "leave":
+      return "danger";
+  }
+}
